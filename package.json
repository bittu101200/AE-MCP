{
  "name": "after-effects-mcp",
  "version": "1.0.0",
  "description": "MCP server for Adobe After Effects",
  "author": "Bhupendra Sharma",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bittu101200/AE-MCP.git"
  },
  "homepage": "https://github.com/bittu101200/AE-MCP",
  "main": "build/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc && copyfiles -u 1 \"src/scripts/**/*\" build",
    "start": "node build/index.js",
    "install-bridge": "node install-bridge.js",
    "showcase": "node showcase/showpiece-demo.js",
    "test": "npm run build && node --test tests/*.test.mjs",
    "postinstall": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "node-fetch": "^3.3.2",
    "zod": "^3.22.2"
  },
  "devDependencies": {
    "@types/node": "^20.17.30",
    "copyfiles": "^2.4.1",
    "typescript": "^5.2.2"
  }
}
